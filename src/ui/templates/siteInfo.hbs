<div id='popup-window-top-bar' class='flex items-center justify-between border-b border-gray-100 px-4'>
  <nav>
    <ul class='flex list-none gap-1 pl-0' role='tablist'>
      <li role='presentation'>
        <button
          role='tab'
          aria-controls='tabs-site-info'
          aria-selected='true'
          disabled
          class='tab-button tab-button-active'
          id='site-info-menu-show-site-info'
        >Paikan tiedot</button>
      </li>
      <li role='presentation'>
        <button
          aria-controls='tabs-site-results'
          aria-selected='false'
          id='site-info-menu-show-results'
          class='tab-button'
        >Paikan tulokset</button>
      </li>
    </ul>
  </nav>
  <button
    type='button'
    id='popup-window-hide-button'
    class='flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600'
  >
    <svg class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
      <path stroke-linecap='round' stroke-linejoin='round' d='M6 18L18 6M6 6l12 12' />
    </svg>
  </button>
</div>
<div id='popup-window-contents' style='height: 87vh;' class='flex flex-col'>
  <div class='flex-1 overflow-y-auto px-4 py-3'>
    {{#each siteAttributes}}
      <div class='border-b border-gray-50 px-2 py-3 sm:flex sm:gap-4'>
        <dt class='text-sm font-medium text-gray-500 sm:w-1/3'>{{name}}</dt>
        <dd class='mt-0.5 text-sm text-gray-900 sm:mt-0 sm:w-2/3'>{{value}}</dd>
      </div>
    {{/each}}
  </div>
</div>
<div id='popup-window-top-bar' class='flex items-center justify-between border-b border-gray-100 px-4'>
  <nav>
    <ul class='flex list-none gap-1 pl-0' role='tablist'>
      <li role='presentation'>
        <button
          role='tab'
          aria-controls='tabs-site-info'
          aria-selected='false'
          class='tab-button'
          id='site-info-menu-show-site-info'
        >Paikan tiedot</button>
      </li>
      <li role='presentation'>
        <button
          aria-controls='tabs-site-results'
          aria-selected='true'
          disabled
          class='tab-button tab-button-active'
        >Paikan tulokset</button>
      </li>
    </ul>
  </nav>
  <button
    type='button'
    id='popup-window-hide-button'
    class='flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600'
  >
    <svg class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
      <path stroke-linecap='round' stroke-linejoin='round' d='M6 18L18 6M6 6l12 12' />
    </svg>
  </button>
</div>
<div id='popup-window-contents' style='height: 87vh;' class='flex flex-col overflow-hidden'>
  <div class='mt-1 grid auto-rows-min grid-cols-3 overflow-hidden sm:grid-cols-4'>
    <div
      class='col-span-3 row-span-1 overflow-y-auto border-r border-gray-100 sm:col-span-1 sm:row-span-2'
      style='max-height: 86vh;'
    >
      <div class='max-h-44 sm:max-h-none'>
        <div class='flex flex-col gap-1 p-2' id='charts-result-set-choices'>

        </div>
      </div>
    </div>
    <div class='col-span-3 row-span-1'>
      <div class='relative w-full' style='height:{{chartHeight}}px;'>
        <div
          id='flot-charts-placeholder'
          class='absolute left-0 top-0 col-start-1 row-start-1 w-full'
          style='height:{{chartHeight}}px;'
        ></div>
        <div
          id='no-selected-result-set-message'
          class='absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gray-50/80 p-5 text-center'
          style='height:{{chartHeight}}px;'
        >
          <svg class='h-10 w-10 text-gray-300' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='1.5'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z'
            />
          </svg>
          <p class='text-sm font-medium text-gray-500'>Valitse tuloksia vasemmalta nähdäksesi kuvaajan</p>
        </div>
      </div>
    </div>
    <div class='col-span-2 flex flex-col gap-2 border-t border-gray-100 p-3'>
      <p class='text-xs font-semibold uppercase tracking-wide text-gray-400'>Kohdistustapa</p>
      <label class='flex cursor-pointer items-center gap-2 text-sm text-gray-700'>
        <input
          class='h-4 w-4 accent-blue-600'
          type='radio'
          name='charts-way-to-zoom'
          id='charts-way-to-zoom-1'
          value='selection'
        />
        Hiiren valinta
      </label>
      <label class='flex cursor-pointer items-center gap-2 text-sm text-gray-700'>
        <input
          class='h-4 w-4 accent-blue-600'
          type='radio'
          name='charts-way-to-zoom'
          id='charts-way-to-zoom-2'
          value='scroll'
          checked
        />
        Rulla ja vetäminen
      </label>
      <button
        type='button'
        class='mt-1 max-w-56 rounded-lg bg-blue-600 px-4 py-2 text-xs font-semibold text-white shadow-sm transition-colors hover:bg-blue-700 active:bg-blue-800'
        id='charts-initial-extent-button'
      >Alkuperäinen rajaus</button>
    </div>
    <div class='relative col-span-1 inline-block overflow-y-auto border-t border-gray-100 p-3'>
      <div id='flot-charts-legend-placeholder' class='absolute block'>
      </div>
    </div>
  </div>
</div>